# hello-operator environment variables
# Copy this file to .env and fill in real values (or export variables directly).
# Never commit .env — it contains secrets.

# Required: Plex authentication token (find it in Plex Web → Account → Authorized Devices)
PLEX_TOKEN=your_plex_token_here

# Required: Machine identifier of the local Plex player that hello-operator controls
# (find it in Plex Web → Settings → Remote Access, or via GET /clients on your Plex server)
PLEX_PLAYER_IDENTIFIER=your_plex_player_machine_identifier_here

# Optional: URL of your Plex Media Server (default: http://localhost:32400)
PLEX_URL=http://localhost:32400
